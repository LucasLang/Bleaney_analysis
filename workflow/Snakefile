configfile: "../config/config.yaml"

import os
from glob import glob

# Access arguments passed via --config in Snakemake
arg1 = config.get("arg1", None)
arg2 = config.get("arg2", None)
arg3 = config.get("arg3", None)

Ln_wildcards = glob_wildcards("data/Bkq_{Ln}_real").Ln   # this will give a list of strings containing the lanthanides

rule all:
    input: 
        expand("results/Ln/{Ln}/error_analysis_plot.png", Ln=Ln_wildcards),
        expand("results/Ln/{Ln}/h_plot.png", Ln=Ln_wildcards)

rule create_finitediff_functions:
    output:
        config['finitediff_file']
    params:
        stencil_size = config['stencil_size'],
        outfile = config['finitediff_file']
    shell:
        "julia scripts/create_finitediff_functions.jl {params.stencil_size} {params.outfile}"

rule TM_workflow:
    output:
        "data/spin_dyadics_input.txt",
        "data/S.txt",
        "data/D.txt",
        "data/T.txt",
        "data/ratio.txt"
    shell:
        "julia scripts/new_DTensor_func.jl {arg1} {arg2} {arg3} {output[0]} {output[1]} {output[2]} {output[3]} {output[4]}"

rule calc_hnorms_Ln:
    input:
        "data/Bkq_{Ln}_real",
        last=config['finitediff_file']
    output:
        "results/Ln/{Ln}/h_norms.txt"
    params:
        h_minexp = config['h_minexp'],
        h_maxexp = config['h_maxexp']
    shell:
        "julia scripts/h_sans_beta_Ln.jl {params.h_minexp} {params.h_maxexp} {input.last} {wildcards.Ln} {output}"

rule calc_hnorms_TM:
    input:
        "data/spin_dyadics_input.txt",
        "data/S.txt",
        "data/D.txt",
        "data/ratio.txt",
        "data/T.txt",
        last=config['finitediff_file']
    output:
        "results/h_norms.txt"
    params:
        h_minexp = config['h_minexp'],
        h_maxexp = config['h_maxexp']
    shell:
        "julia scripts/h_sans_beta_TM.jl {params.h_minexp} {params.h_maxexp} {input.last}"

rule h_plot:
    input:
        "results/{folder}/h_norms.txt"
    output:
        "results/{folder}/h_plot.png"
    conda:
        "envs/matplotlib.yaml"
    params:
        h_minexp = config['h_minexp'],
        h_maxexp = config['h_maxexp']
    shell:
        "python scripts/h2_plots.py {params.h_minexp} {params.h_maxexp} {input} {output}"

rule optimize_h:
    input:
        "results/Ln/{Ln}/h_norms.txt"
    output:
        "results/Ln/{Ln}/optimal_h_value.txt",
    params:
        h_minexp = config['h_minexp'],
        h_maxexp = config['h_maxexp']
    shell:
        "python scripts/optimal_hvalues.py {params.h_minexp} {params.h_maxexp} {input} {output}"

rule calc_run_Ln:
    input:
        "data/Bkq_{Ln}_real",
        h = "results/Ln/{Ln}/optimal_h_value.txt",
        last=config['finitediff_file']
    output:
        "results/Ln/{Ln}/diff_norms.txt"
    params:
        Tmin = config['Ln_Tmin'],
        Tmax = config['Ln_Tmax'],
        Tinterval = config['Ln_Tinterval']
    shell:
        "julia scripts/dyadics_Ln.jl {params.Tmin} {params.Tmax} {params.Tinterval} {input.h} {input.last} {wildcards.Ln} {output}"

rule calc_run_TM:
    input:
        "data/spin_dyadics_input.txt",
        "data/S.txt",
        "data/D.txt",
        "data/ratio.txt",
        "data/T.txt",
        "results/optimal_h_value.txt",
        last=config['finitediff_file']
    output:
        "results/diff_norms.txt"
    params:
        Tmin = config['Ln_Tmin'],
        Tmax = config['Ln_Tmax'],
        Tinterval = config['Ln_Tinterval']
    shell:
        "julia scripts/dyadics_TM.jl {params.Tmin} {params.Tmax} {params.Tinterval} results/optimal_h_value.txt {input.last}"

rule dyadic_plot:
    input:
        "results/{folder}/{system}/diff_norms.txt",
    output:
        "results/{folder}/{system}/error_analysis_plot.png"
    conda:
        "envs/matplotlib.yaml"
    params:
        Tmin = config['Ln_Tmin'],
        Tmax = config['Ln_Tmax'],
        Tinterval = config['Ln_Tinterval']
    shell:
        "python scripts/errorplot_{wildcards.folder}.py {params.Tmin} {params.Tmax} {params.Tinterval} {input} {wildcards.system} {output}"

