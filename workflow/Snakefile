        Tmin = config['Ln_Tmin'],
        Tmax = config['Ln_Tmax'],
        Tinterval = config['Ln_Tinterval']
    shell:
        "python scripts/errorplot_Ln_2in1.py {params.Tmin} {params.Tmax} {params.Tinterval} {input[0]} {wildcards.ln1} {input[1]} {wildcards.ln2} {output}"

rule dyadic_plot_TM:
    input:
        "results/TM/S_{S}/E_{E}/D_{D}/diff_norms.txt",
        "results/TM/S_{S}/E_{E}/D_{D}/T.txt"
    output:
        "results/TM/S_{S}/E_{E}/D_{D}/error_analysis_plot_S_{S}_E_{E}_D_{D}.png"
    conda:
        "envs/matplotlib.yaml"
    shell:
        "python scripts/errorplot_TM.py {wildcards.S} {wildcards.E} {wildcards.D} {input[0]} {input[1]} {output}"

rule dyadic_plot_TM_2in1:
    input:
        "results/TM/S_{S1}/E_{E1}/D_{D1}/diff_norms.txt",
        "results/TM/S_{S1}/E_{E1}/D_{D1}/T.txt",
        "results/TM/S_{S2}/E_{E2}/D_{D2}/diff_norms.txt",
        "results/TM/S_{S2}/E_{E2}/D_{D2}/T.txt"
    output:
        "results/TM/error_analysis_plot_2in1_{S1}_{E1}_{D1}_{S2}_{E2}_{D2}.png"
    conda:
        "envs/matplotlib.yaml"
    shell:
        "python scripts/errorplot_TM_2in1.py {wildcards.S1} {wildcards.E1} {wildcards.D1} {input[0]} {input[1]} {wildcards.S2} {wildcards.E2} {wildcards.D2} {input[2]} {input[3]} {output}"
